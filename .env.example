# ------------------------------------------------------------------
# BodhanAI — environment configuration
# Copy this file to .env and fill in your own keys.
# Never commit your real .env file (it's already in .gitignore).
# ------------------------------------------------------------------

# Groq API key — powers the main chat LLM (openai/gpt-oss-120b via ChatGroq).
# Get one at https://console.groq.com/keys
# Required.
GROQ_API_KEY=your_groq_api_key_here

# Tavily API key — powers the live web search tool (TavilySearch).
# Get one at https://app.tavily.com
# Required — the app raises an error on startup if this is missing.
TAVILY_API_KEY=your_tavily_api_key_here

# Groq API key used specifically for audio transcription (Whisper large-v3)
# when a user records a voice message via the mic input.
# Can be the same value as GROQ_API_KEY, or a separate key if you want to
# track/limit speech usage independently.
# Required for the voice input feature.
GROQ_SPEECH_API_KEY=your_groq_speech_api_key_here
